APP_NAME=Production RAG
APP_VERSION=1.0.0
ENVIRONMENT=local
LOG_LEVEL=INFO
PLATFORM_PROFILE=enterprise
DOCUMENT_DOMAIN=legal

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY="api_key"
QDRANT_COLLECTION=documents

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

TOP_K_DENSE=30
TOP_K_SPARSE=30
TOP_K_FINAL=8
DOCUMENT_CHUNK_SIZE=1200
DOCUMENT_CHUNK_OVERLAP=150
LEGAL_CITATIONS_REQUIRED=true
LEGAL_REQUIRED_METADATA_FIELDS=tenant_id,department,role,tags

# Authentication
SECRET_KEY=supersecretkey
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=production_rag

# S3 / MinIO
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=production-rag-docs
S3_REGION=us-east-1
